		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@types/uuid": "^10.0.0",
		"@vitest/coverage-v8": "^4.1.9",
		"prisma": "^7.8.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.7.2",
		"vitest": "^4.1.9"
	}
