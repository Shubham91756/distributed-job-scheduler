{
	"name": "distributed-job-scheduler-daemon",
	"version": "1.0.0",
	"private": true,
	"main": "dist/scheduler.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/scheduler.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/scheduler.js",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@prisma/client": "^6.0.0",
		"cron-parser": "^5.6.1",
		"dotenv": "^16.4.5",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"prisma": "^6.0.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.7.2"
	}
}
