{
	"name": "distributed-job-scheduler",
	"version": "1.0.0",
	"private": true,
	"workspaces": [
		"backend",
		"frontend",
		"worker",
		"scheduler"
	],
	"scripts": {
		"dev:backend": "npm --workspace backend run dev",
		"dev:frontend": "npm --workspace frontend run dev",
		"dev:worker": "npm --workspace worker run dev",
		"dev:scheduler": "npm --workspace scheduler run dev",
		"build:backend": "npm --workspace backend run build",
		"build:frontend": "npm --workspace frontend run build",
		"build:worker": "npm --workspace worker run build",
		"build:scheduler": "npm --workspace scheduler run build",
		"typecheck:backend": "npm --workspace backend run typecheck",
		"typecheck:frontend": "npm --workspace frontend run typecheck",
		"typecheck:worker": "npm --workspace worker run typecheck",
		"typecheck:scheduler": "npm --workspace scheduler run typecheck",
		"build": "npm run build:backend && npm run build:frontend && npm run build:worker && npm run build:scheduler",
		"typecheck": "npm run typecheck:backend && npm run typecheck:frontend && npm run typecheck:worker && npm run typecheck:scheduler"
	}
}
